import { ExponentialCost } from "./api/Costs";
import { BigNumber } from "./api/BigNumber";
import { theory } from "./api/Theory";
import { Utils } from "./api/Utils";

var id = "adaptive_multi_regime";
var name = "Adaptive Multi-Regime Stability";
var description = "Stable equilibrium growth with smooth resonance dynamics.";
var authors = "qrze, melon (refactored)";
var version = 5.1;

requiresGameVersion("1.4.33");

var currency;

var x = BigNumber.ONE;
var E = BigNumber.ONE;
var S = BigNumber.from(1.1);
var D = BigNumber.from(0.1);

var a1, a2, c1, c2, alpha;
var milestoneResonance, milestoneEquilibriumBoost, milestoneStressFeedback;

const ONE = BigNumber.ONE;
const ZERO = BigNumber.ZERO;
const SAFE_E_FLOOR = BigNumber.from(1e-10);
const DELTA = BigNumber.from(0.1);
const ONE_POINT_FIVE = BigNumber.from(1.5);

var init = () =>
{
    currency = theory.createCurrency();

    // ---------------- Upgrades ----------------

    a1 = theory.createUpgrade(0, currency, new ExponentialCost(5, 2));
    a1.getDescription = _ =>
        Utils.getMath("a_1 = " + (0.1 + 0.05*a1.level).toFixed(2));

    a2 = theory.createUpgrade(1, currency, new ExponentialCost(10, 2.2));
    a2.getDescription = _ =>
        Utils.getMath("a_2 = 0.05 \\cdot 0.9^{" + a2.level + "}");

    c1 = theory.createUpgrade(2, currency, new ExponentialCost(20, 2.5));
    c1.getDescription = _ =>
        Utils.getMath("c_1 = " + (0.05 + 0.03*c1.level).toFixed(3));

    alpha = theory.createUpgrade(3, currency, new ExponentialCost(50, 3));
    alpha.getDescription = _ =>
        Utils.getMath("\\alpha = " + (1 + 0.02*alpha.level).toFixed(3));

    c2 = theory.createUpgrade(4, currency, new ExponentialCost(1e10, 5));
    c2.getDescription = _ =>
        Utils.getMath("\\beta = 1.5^{" + c2.level + "}");

    // ---------------- Publication ----------------

    theory.createPublicationUpgrade(0, currency, 1e8);
    theory.createBuyAllUpgrade(1, currency, 1e15);
    theory.createAutoBuyerUpgrade(2, currency, 1e25);

    // ---------------- Milestones ----------------

    theory.setMilestoneCost(new ExponentialCost(5, 2));

    milestoneResonance = theory.createMilestoneUpgrade(0, 1);
    milestoneResonance.description = "Double growth near equilibrium";

    milestoneEquilibriumBoost = theory.createMilestoneUpgrade(1, 1);
    milestoneEquilibriumBoost.description = "Add log(x) to dE/dt";

    milestoneStressFeedback = theory.createMilestoneUpgrade(2, 1);
    milestoneStressFeedback.description = "Convert stress into stability";
};

var tick = (elapsedTime, multiplier) =>
{
    let dt = BigNumber.from(elapsedTime * multiplier);

    // Upgrade values
    let A = BigNumber.from(0.1 + 0.05 * a1.level);
    let B = BigNumber.from(0.05)
        .times(BigNumber.from(0.9).pow(a2.level));
    let C = BigNumber.from(0.05 + 0.03 * c1.level);
    let Alpha = BigNumber.from(1 + 0.02 * alpha.level);
    let beta = ONE_POINT_FIVE.pow(c2.level);

    let safeE = E.compareTo(SAFE_E_FLOOR) > 0 ? E : SAFE_E_FLOOR;
    let ratio = x.div(safeE);

    // ---------------- dE ----------------
    let dE = A.times(x.pow(Alpha)).minus(B.times(E));

    if (milestoneEquilibriumBoost.level > 0)
    {
        let logTerm = Math.log(x.plus(ONE).toNumber());
        dE = dE.plus(BigNumber.from(logTerm));
    }

    // ---------------- dS ----------------
    let ratioDiff = ratio.minus(ONE).toNumber();
    let absValue = Math.abs(ratioDiff);

    let dS = C.minus(BigNumber.from(0.05 * absValue));

    if (milestoneStressFeedback.level > 0)
    {
        let sqrtTerm = Math.sqrt(D.toNumber());
        dS = dS.plus(BigNumber.from(0.05 * sqrtTerm));
    }

    // ---------------- dD ----------------
    let dD = BigNumber.from(0.1)
        .times(ratio.pow(2))
        .minus(BigNumber.from(0.1).times(S))
        .minus(BigNumber.from(0.003).times(D));

    D = D.plus(dD.times(dt));

    if (D.compareTo(BigNumber.from(0.1)) < 0)
        D = BigNumber.from(0.1);

    if (D.compareTo(BigNumber.from(100)) > 0)
        D = BigNumber.from(100);

    // ---------------- Logistic Growth ----------------
    let logistic = S.times(x)
        .times(ONE.minus(x.div(safeE)))
        .div(ONE.plus(DELTA.times(D)));

    if (logistic.compareTo(BigNumber.from(0.02)) < 0)
        logistic = BigNumber.from(0.02);

    if (milestoneResonance.level > 0)
    {
        if (ratio.compareTo(BigNumber.from(0.95)) > 0 &&
            ratio.compareTo(BigNumber.from(1.05)) < 0)
        {
            logistic = logistic.times(2);
        }
    }

    let growth = beta.times(logistic);

    // ---------------- Apply updates ----------------
    x = x.plus(growth.times(dt));
    E = E.plus(dE.times(dt));

    if (E.compareTo(SAFE_E_FLOOR) < 0)
        E = SAFE_E_FLOOR;

    S = S.plus(dS.times(dt));

    if (S.compareTo(BigNumber.from(0.1)) < 0)
        S = BigNumber.from(0.1);

    currency.value = currency.value.plus(x.times(dt));

    theory.invalidateTertiaryEquation();
};

// ---------------- Save State ----------------

var getInternalState = () =>
    x.toString() + " " +
    E.toString() + " " +
    S.toString() + " " +
    D.toString();

var setInternalState = (state) =>
{
    let v = state.split(" ");
    if (v.length >= 4)
    {
        x = BigNumber.from(v[0]);
        E = BigNumber.from(v[1]);
        S = BigNumber.from(v[2]);
        D = BigNumber.from(v[3]);
    }
};

// ---------------- Equations ----------------

var getPrimaryEquation = () =>
    "\\dot{x} = \\beta \\frac{Sx(1 - x/E)}{1+0.1D}";

var getSecondaryEquation = () =>
    "\\dot{E} = a_1 x^{\\alpha} - a_2 E";

var getTertiaryEquation = () =>
    "S=" + S.toFixed(2) + ",\\quad D=" + D.toFixed(2);

var getPublicationMultiplier = tau =>
    tau.pow(0.85);

var getPublicationFormula = () =>
    "\\tau = \\rho^{0.18}";

init();
